{
  "name": "carbonlens",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "CarbonLens — Track, understand, and reduce your personal carbon footprint with data-driven insights and actionable recommendations.",
  "license": "MIT",
  "author": "kavixsri",
  "repository": {
    "type": "git",
    "url": "https://github.com/kavixsri/Climate.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:security": "vitest run tests/security",
    "test:a11y": "vitest run tests/accessibility",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{js,css,html}\""
  },
  "dependencies": {
    "chart.js": "^4.4.7"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.1",
    "axe-core": "^4.12.1",
    "axe-puppeteer": "^1.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.6",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.4",
    "puppeteer": "^25.1.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.1"
  }
}
